---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/ui/Section.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import Icon from '@/components/ui/Icon.astro';

const lang = 'es';

const products = [
  {
    title: 'Tintas e Vernizes',
    description: 'Pinturas de alta reflectividad y durabilidad superior',
    icon: 'paint',
    image: 'https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=600&q=80',
    slug: 'tintas-vernizes',
  },
  {
    title: 'Termoplásticos',
    description: 'Soluciones termoplásticas con adherencia excepcional',
    icon: 'truck',
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&q=80',
    slug: 'termoplasticos',
  },
  {
    title: 'Plástico a Frio',
    description: 'Aplicación rápida sin requerir calor',
    icon: 'zap',
    image: 'https://images.unsplash.com/photo-1581092162562-40038e57d0f7?w=600&q=80',
    slug: 'plastico-frio',
  },
  {
    title: 'Piso Podotácil',
    description: 'Pisos tácti para orientación de personas',
    icon: 'shield',
    image: 'https://images.unsplash.com/photo-1581092178562-40038e57d0f7?w=600&q=80',
    slug: 'piso-podotactil',
  },
  {
    title: 'Microesferas de Vidrio',
    description: 'Perlas reflectoras de alta calidad',
    icon: 'zap',
    image: 'https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=600&q=80',
    slug: 'microesferas-vidrio',
  },
  {
    title: 'Tachas e Tachões',
    description: 'Elementos de fijación vial',
    icon: 'target',
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&q=80',
    slug: 'tachas-tachoes',
  },
  {
    title: 'Colas e Adesivos',
    description: 'Adhesivos para aplicaciones viales',
    icon: 'briefcase',
    image: 'https://images.unsplash.com/photo-1581092162562-40038e57d0f7?w=600&q=80',
    slug: 'colas-adesivos',
  },
  {
    title: 'Pisos Industriales',
    description: 'Pisos para entornos industriales',
    icon: 'factory',
    image: 'https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=600&q=80',
    slug: 'pisos-industriales',
  },
  {
    title: 'Pisos Decorativos',
    description: 'Pisos decorativos y de seguridad',
    icon: 'award',
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&q=80',
    slug: 'pisos-decorativos',
  },
  {
    title: 'Préformados',
    description: 'Elementos prefabricados viales',
    icon: 'grid',
    image: 'https://images.unsplash.com/photo-1581092162562-40038e57d0f7?w=600&q=80',
    slug: 'preformados',
  },
];
---

<BaseLayout
  lang={lang}
  title="Productos | CNSA Paraguay"
  description="Conozca nuestro portafolio de productos de marcaje vial, materiales termoplásticos y soluciones de seguridad."
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-b from-dark-secondary to-dark pt-32 pb-16">
    <div class="container-premium">
      <h1 class="text-5xl md:text-6xl font-body font-bold text-white mb-6">
        Nuestros Productos
      </h1>
      <p class="text-lg text-gray max-w-3xl">
        Soluciones completas de marcaje vial, materiales termoplásticos y seguridad en carreteras de calidad mundial.
      </p>
    </div>
  </section>

  <!-- Products Grid -->
  <Section title="Catálogo de Productos">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
      {products.map(product => (
        <Card class="overflow-hidden group flex flex-col">
          <div class="relative h-48 overflow-hidden rounded-sm mb-6 -m-6 mb-6">
            <img
              src={product.image}
              alt={product.title}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            />
          </div>
          <Icon name={product.icon as any} size={32} class="text-primary mb-4" />
          <h3 class="text-base font-body font-bold text-white mb-2 flex-1">
            {product.title}
          </h3>
          <p class="text-gray text-xs mb-6 flex-1">{product.description}</p>

          <div class="flex items-center gap-2 mt-auto pt-4 border-t border-[rgba(255,255,255,0.08)]">
            <Button href={`/products/${product.slug}`} variant="primary" size="sm">
              Ver
              <Icon name="arrow-right" size={14} />
            </Button>
          </div>
        </Card>
      ))}
    </div>
  </Section>

  <!-- Product Categories -->
  <Section title="Categorías de Productos" class="bg-dark-secondary">
    <p class="text-base text-gray max-w-3xl mb-12">
      Nuestro portafolio cubre todas las necesidades de marcaje vial y seguridad en carreteras. Explora nuestras categorías principales:
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <Card class="text-center">
        <Icon name="paint" size={40} class="text-primary mx-auto mb-4" />
        <h4 class="font-body font-bold text-white mb-2">Pinturas Viales</h4>
        <p class="text-sm text-gray mb-4">Pinturas de alta reflectividad y durabilidad</p>
        <Button href="/products" variant="ghost" size="sm">Ver →</Button>
      </Card>

      <Card class="text-center">
        <Icon name="truck" size={40} class="text-primary mx-auto mb-4" />
        <h4 class="font-body font-bold text-white mb-2">Termoplásticos</h4>
        <p class="text-sm text-gray mb-4">Soluciones termoplásticas premium</p>
        <Button href="/products" variant="ghost" size="sm">Ver →</Button>
      </Card>

      <Card class="text-center">
        <Icon name="zap" size={40} class="text-primary mx-auto mb-4" />
        <h4 class="font-body font-bold text-white mb-2">Perlas de Vidrio</h4>
        <p class="text-sm text-gray mb-4">Perlas reflectoras de calidad ISO</p>
        <Button href="/products" variant="ghost" size="sm">Ver →</Button>
      </Card>

      <Card class="text-center">
        <Icon name="shield" size={40} class="text-primary mx-auto mb-4" />
        <h4 class="font-body font-bold text-white mb-2">Seguridad Vial</h4>
        <p class="text-sm text-gray mb-4">Sistemas integrales de protección</p>
        <Button href="/products" variant="ghost" size="sm">Ver →</Button>
      </Card>
    </div>
  </Section>

  <!-- Final CTA -->
  <Section class="bg-gradient-orange text-white text-center">
    <h2 class="text-4xl md:text-5xl font-body font-bold mb-6">
      ¿Necesitas una Solución Personalizada?
    </h2>
    <p class="text-lg mb-8 max-w-2xl mx-auto opacity-90">
      Contacta a nuestro equipo de especialistas para obtener asesoramiento técnico y cotizaciones.
    </p>
    <Button href="/contact" variant="primary" size="lg">
      Solicitar Cotización
    </Button>
  </Section>
</BaseLayout>
