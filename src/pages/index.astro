---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Section from '@/components/ui/Section.astro';
import Card from '@/components/ui/Card.astro';
import Icon from '@/components/ui/Icon.astro';

const lang = 'es';

const stats = [
  { number: '20+', label: 'Años' },
  { number: '500+', label: 'Proyectos' },
  { number: '5000+', label: 'Kilómetros' },
  { number: '200+', label: 'Clientes' },
];

const products = [
  {
    icon: 'paint',
    title: 'Tintas e Vernizes',
    description: 'Pinturas de alta reflectividad y durabilidad superior',
    slug: 'tintas-vernizes',
  },
  {
    icon: 'truck',
    title: 'Termoplásticos',
    description: 'Soluciones termoplásticas con adherencia excepcional',
    slug: 'termoplasticos',
  },
  {
    icon: 'zap',
    title: 'Plástico a Frio',
    description: 'Aplicación rápida sin requerir calor',
    slug: 'plastico-frio',
  },
  {
    icon: 'shield',
    title: 'Piso Podotátil',
    description: 'Pisos tácti para orientación de personas con discapacidad visual',
    slug: 'piso-podotactil',
  },
  {
    icon: 'zap',
    title: 'Microesferas de Vidro',
    description: 'Perlas reflectoras de alta calidad para máxima visibilidad',
    slug: 'microesferas-vidrio',
  },
  {
    icon: 'target',
    title: 'Tachas e Tachões',
    description: 'Elementos de fijación y demarcación vial',
    slug: 'tachas-tachoes',
  },
  {
    icon: 'briefcase',
    title: 'Colas e Adesivos',
    description: 'Adhesivos especializados para aplicaciones viales',
    slug: 'colas-adesivos',
  },
  {
    icon: 'factory',
    title: 'Pisos Industriais',
    description: 'Soluciones de piso para entornos industriales y comerciales',
    slug: 'pisos-industriales',
  },
  {
    icon: 'award',
    title: 'Pisos Decorativos',
    description: 'Pisos decorativos y de seguridad personalizados',
    slug: 'pisos-decorativos',
  },
  {
    icon: 'grid',
    title: 'Préformados',
    description: 'Elementos prefabricados para aplicación rápida y precisa',
    slug: 'preformados',
  },
];

const process = [
  { step: '01', title: 'Consulta', desc: 'Evaluación de tus necesidades' },
  { step: '02', title: 'Diseño', desc: 'Solución personalizada' },
  { step: '03', title: 'Ejecución', desc: 'Implementación profesional' },
  { step: '04', title: 'Soporte', desc: 'Mantenimiento y seguimiento' },
];

const projects = [
  {
    title: 'Ruta 2 Asunción - Coronel Oviedo',
    category: 'Carreteras',
    image: 'https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=800&q=80',
  },
  {
    title: 'Sistema BRT Asunción',
    category: 'Urbano',
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=800&q=80',
  },
  {
    title: 'Proyecto Seguridad Ruta 1',
    category: 'Seguridad',
    image: 'https://images.unsplash.com/photo-1581092162562-40038e57d0f7?w=800&q=80',
  },
];
---

<BaseLayout lang={lang}>
  <!-- Hero Section with YouTube Video -->
  <section class="relative h-screen bg-dark flex items-center justify-center overflow-hidden pt-20">
    <!-- YouTube Background Video -->
    <div class="absolute inset-0 w-full h-full overflow-hidden">
      <iframe
        id="hero-video"
        src="https://www.youtube.com/embed/yQXJfJCt7sU?autoplay=1&muted=1&loop=1&controls=0&playlist=yQXJfJCt7sU&rel=0&showinfo=0&disablekb=1&modestbranding=1&iv_load_policy=3&fs=0"
        class="absolute top-1/2 left-1/2 w-[177.78vh] h-[56.25vw] min-w-full min-h-full -translate-x-1/2 -translate-y-1/2"
        allow="autoplay; fullscreen"
        frameborder="0"
      ></iframe>
      <!-- Dark Overlay -->
      <div class="absolute inset-0 bg-black/70"></div>
    </div>

    <!-- Hero Content -->
    <div class="relative z-10 container-premium text-center">
      <h1 class="text-5xl md:text-7xl font-body font-bold text-white mb-6 leading-tight">
        Road Safety Starts With Precision
      </h1>
      <p class="text-lg md:text-xl text-gray max-w-2xl mx-auto mb-12">
        Soluciones premium de marcaje vial para carreteras, espacios urbanos e infraestructura crítica
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/contact" variant="primary" size="lg">
          <Icon name="arrow-right" size={18} />
          Solicitar Cotización
        </Button>
        <Button href="#products" variant="outline" size="lg">
          <Icon name="play" size={18} />
          Explorar Soluciones
        </Button>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-10">
      <Icon name="chevron-down" size={24} class="text-primary" />
    </div>
  </section>

  <!-- Stats Section -->
  <section class="bg-dark-secondary py-12 md:py-20 border-y border-[rgba(255,255,255,0.08)]">
    <div class="container-premium">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-0">
        {stats.map((stat, idx) => (
          <div class="text-center py-8 px-4" data-stat={stat.number} style={idx < stats.length - 1 ? 'border-right: 1px solid rgba(255,255,255,0.15)' : ''}>
            <h3 class="text-5xl md:text-6xl font-body font-bold text-primary mb-3">
              {stat.number}
            </h3>
            <p class="text-gray-light text-sm font-medium">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <Section id="products" title="Nuestros Productos" subtitle="Soluciones completas para cada necesidad">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
      {products.map(product => (
        <Card class="flex flex-col">
          <Icon name={product.icon as any} size={32} class="text-primary mb-4" />
          <h3 class="text-base font-body font-bold text-white mb-2 flex-1">{product.title}</h3>
          <p class="text-gray text-xs mb-4 flex-1">{product.description}</p>
          <Button href={`/products/${product.slug}`} variant="ghost" size="sm" class="self-start">
            <Icon name="arrow-right" size={14} />
            Ver
          </Button>
        </Card>
      ))}
    </div>
  </Section>

  <!-- Company Overview -->
  <Section class="bg-dark-secondary">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <img
          src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&q=80"
          alt="Company Overview"
          class="rounded-sm w-full"
        />
      </div>
      <div>
        <h2 class="text-4xl md:text-5xl font-body font-bold text-white mb-6">
          Excelencia Industrial Desde Paraguay
        </h2>
        <p class="text-base text-gray mb-6">
          Con más de 20 años de experiencia, CNSA Paraguay es líder en soluciones de marcaje vial y seguridad en carreteras. Nuestro compromiso con la calidad y la innovación nos ha posicionado como partners de confianza.
        </p>
        <ul class="space-y-4 mb-8">
          <li class="flex items-start gap-3">
            <Icon name="check" size={20} class="text-primary mt-1 flex-shrink-0" />
            <span class="text-gray">Certificaciones internacionales de calidad</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check" size={20} class="text-primary mt-1 flex-shrink-0" />
            <span class="text-gray">Procesos de producción avanzados</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check" size={20} class="text-primary mt-1 flex-shrink-0" />
            <span class="text-gray">Equipo especialista en ingeniería vial</span>
          </li>
        </ul>
        <Button href="/about" variant="primary">Conocer Más</Button>
      </div>
    </div>
  </Section>

  <!-- Process Section -->
  <Section title="Nuestro Proceso">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      {process.map((item, idx) => (
        <div key={idx} class="relative">
          <div class="bg-dark-secondary border border-[rgba(255,255,255,0.08)] rounded-sm p-8 text-center">
            <div class="text-4xl font-body font-bold text-primary mb-4">{item.step}</div>
            <h4 class="font-body font-bold text-white mb-2">{item.title}</h4>
            <p class="text-gray text-sm">{item.desc}</p>
          </div>
          {idx < process.length - 1 && (
            <div class="hidden md:block absolute top-1/2 -right-3 w-6 h-0.5 bg-primary -translate-y-1/2"></div>
          )}
        </div>
      ))}
    </div>
  </Section>

  <!-- Projects Preview -->
  <Section title="Proyectos Destacados" class="bg-dark-secondary">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      {projects.map(project => (
        <div class="group relative overflow-hidden rounded-sm h-64">
          <img
            src={project.image}
            alt={project.title}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-black/60 group-hover:bg-black/70 transition-all duration-300 flex items-end p-6">
            <div>
              <div class="text-primary text-xs font-bold uppercase mb-2">{project.category}</div>
              <h3 class="text-white font-body font-bold text-lg">{project.title}</h3>
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="text-center">
      <Button href="/projects" variant="outline">
        Ver Todos los Proyectos
        <Icon name="arrow-right" size={18} />
      </Button>
    </div>
  </Section>

  <!-- Final CTA -->
  <Section class="bg-gradient-orange text-white">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-4xl md:text-5xl font-body font-bold mb-6">
        ¿Listo para Tu Próximo Proyecto?
      </h2>
      <p class="text-base md:text-lg mb-8 opacity-90">
        Contáctanos hoy para solicitar una cotización personalizada y conocer cómo CNSA puede transformar tu infraestructura vial.
      </p>
      <Button href="/contact" variant="primary" size="lg">
        <Icon name="send" size={18} />
        Comenzar Ahora
      </Button>
    </div>
  </Section>

  <!-- Quick Contact Section -->
  <section class="bg-gradient-to-r from-dark via-dark-secondary to-dark py-16 md:py-20">
    <div class="container-premium">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Call Us -->
        <div class="flex items-start gap-4 lg:pr-8 lg:border-r border-white/20">
          <Icon name="phone" size={32} class="text-primary flex-shrink-0 mt-1" />
          <div>
            <h4 class="font-body font-bold text-white mb-3">Llamar Ahora</h4>
            <p class="text-white text-sm font-bold">(646) 555-0258</p>
            <p class="text-gray-light text-xs">(503) 555-0666</p>
          </div>
        </div>

        <!-- Office Time -->
        <div class="flex items-start gap-4 lg:px-8 lg:border-r border-white/20">
          <Icon name="clock" size={32} class="text-primary flex-shrink-0 mt-1" />
          <div>
            <h4 class="font-body font-bold text-white mb-3">Horario Oficina</h4>
            <p class="text-white text-sm font-bold">Lun-Vie: 9:00 - 17:00</p>
            <p class="text-gray-light text-xs">America/New_York</p>
          </div>
        </div>

        <!-- Support -->
        <div class="flex items-start gap-4 lg:px-8 lg:border-r border-white/20">
          <Icon name="email" size={32} class="text-primary flex-shrink-0 mt-1" />
          <div>
            <h4 class="font-body font-bold text-white mb-3">Soporte</h4>
            <p class="text-white text-sm font-bold">support@cnsa.com</p>
            <p class="text-gray-light text-xs">help@cnsa.com</p>
          </div>
        </div>

        <!-- Address -->
        <div class="flex items-start gap-4 lg:pl-8">
          <Icon name="location" size={32} class="text-primary flex-shrink-0 mt-1" />
          <div>
            <h4 class="font-body font-bold text-white mb-3">Dirección</h4>
            <p class="text-white text-sm font-bold">Asunción, Paraguay</p>
            <p class="text-gray-light text-xs">Piso 2, Sede Central</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const statElement = entry.target as HTMLElement;
        const targetText = statElement.dataset.stat || '';
        const targetNumber = parseInt(targetText.replace(/\D/g, ''), 10);

        if (targetNumber && targetNumber > 0) {
          let current = 0;
          const increment = Math.ceil(targetNumber / 30);
          const interval = setInterval(() => {
            current += increment;
            if (current >= targetNumber) {
              statElement.textContent = targetText;
              clearInterval(interval);
            } else {
              statElement.textContent = current.toString();
            }
          }, 30);
        }
        observer.unobserve(entry.target);
      }
    });
  });

  document.querySelectorAll('[data-stat]').forEach(el => {
    observer.observe(el);
  });
</script>
