---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/ui/Section.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import Icon from '@/components/ui/Icon.astro';

const lang = 'es';

const projects = [
  {
    title: 'Ruta 2 - Asunción a Coronel Oviedo',
    location: 'Paraguay',
    year: 2023,
    image: 'https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=600&q=80',
    category: 'Carreteras',
    description: '250 km de marcaje vial con materiales termoplásticos',
  },
  {
    title: 'Sistema de Transporte Urbano - Asunción',
    location: 'Asunción, Paraguay',
    year: 2023,
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&q=80',
    category: 'Urbano',
    description: 'Señalización completa para carriles de BRT',
  },
  {
    title: 'Proyecto de Seguridad Vial - Ruta 1',
    location: 'Paraguay',
    year: 2022,
    image: 'https://images.unsplash.com/photo-1581092162562-40038e57d0f7?w=600&q=80',
    category: 'Seguridad',
    description: 'Implementación de líneas dobles y señalización preventiva',
  },
];
---

<BaseLayout
  lang={lang}
  title="Proyectos | CNSA Paraguay"
  description="Conozca nuestro portafolio de proyectos ejecutados en carreteras, espacios urbanos y estacionamientos."
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-b from-dark-secondary to-dark pt-32 pb-16">
    <div class="container-premium">
      <h1 class="text-5xl md:text-6xl font-body font-bold text-white mb-6">
        Nuestros Proyectos
      </h1>
      <p class="text-lg text-gray max-w-3xl">
        Más de 500 proyectos ejecutados en carreteras, espacios urbanos y estacionamientos en toda la región.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-dark-secondary py-12 md:py-16 border-y border-[rgba(255,255,255,0.08)]">
    <div class="container-premium grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="text-center">
        <p class="text-4xl md:text-5xl font-body font-bold text-primary mb-2">500+</p>
        <p class="text-gray">Proyectos Completados</p>
      </div>
      <div class="text-center">
        <p class="text-4xl md:text-5xl font-body font-bold text-primary mb-2">5000+</p>
        <p class="text-gray">Kilómetros Marcados</p>
      </div>
      <div class="text-center">
        <p class="text-4xl md:text-5xl font-body font-bold text-primary mb-2">200+</p>
        <p class="text-gray">Clientes Satisfechos</p>
      </div>
      <div class="text-center">
        <p class="text-4xl md:text-5xl font-body font-bold text-primary mb-2">20+</p>
        <p class="text-gray">Años de Experiencia</p>
      </div>
    </div>
  </section>

  <!-- Projects Grid -->
  <Section title="Galería de Proyectos">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map(project => (
        <Card class="overflow-hidden group">
          <div class="relative h-64 overflow-hidden rounded-sm mb-6 -m-6 mb-6">
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            />
            <div class="absolute top-4 right-4 bg-primary text-white px-4 py-2 rounded-sm text-sm font-bold">
              {project.category}
            </div>
          </div>

          <h3 class="text-2xl font-body font-bold text-white mb-2">
            {project.title}
          </h3>

          <div class="flex items-center gap-2 text-gray text-sm mb-4 pb-4 border-b border-[rgba(255,255,255,0.08)]">
            <Icon name="location" size={16} />
            <span>{project.location}</span>
            <span>•</span>
            <span>{project.year}</span>
          </div>

          <p class="text-gray mb-6">{project.description}</p>

          <Button href="/projects" variant="primary">
            Ver Caso de Estudio
            <Icon name="arrow-right" size={16} />
          </Button>
        </Card>
      ))}
    </div>
  </Section>

  <!-- Project Types -->
  <Section title="Tipos de Proyectos" class="bg-dark-secondary">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <Card class="text-center">
        <Icon name="road" size={40} class="text-primary mx-auto mb-4" />
        <h4 class="font-body font-bold text-white mb-2">Carreteras</h4>
        <p class="text-sm text-gray">Marcaje de carreteras nacionales y regionales</p>
      </Card>

      <Card class="text-center">
        <Icon name="building" size={40} class="text-primary mx-auto mb-4" />
        <h4 class="font-body font-bold text-white mb-2">Proyectos Urbanos</h4>
        <p class="text-sm text-gray">Señalización en espacios urbanos y ciudades</p>
      </Card>

      <Card class="text-center">
        <Icon name="target" size={40} class="text-primary mx-auto mb-4" />
        <h4 class="font-body font-bold text-white mb-2">Estacionamientos</h4>
        <p class="text-sm text-gray">Marcaje en estacionamientos y zonas de carga</p>
      </Card>

      <Card class="text-center">
        <Icon name="zap" size={40} class="text-primary mx-auto mb-4" />
        <h4 class="font-body font-bold text-white mb-2">Infraestructura</h4>
        <p class="text-sm text-gray">Señalización en instalaciones especiales</p>
      </Card>
    </div>
  </Section>

  <!-- Final CTA -->
  <Section class="bg-gradient-orange text-white text-center">
    <h2 class="text-4xl md:text-5xl font-body font-bold mb-6">
      ¿Tienes un Proyecto en Mente?
    </h2>
    <p class="text-lg mb-8 max-w-2xl mx-auto opacity-90">
      Contáctanos hoy para discutir tu proyecto y obtener una propuesta personalizada.
    </p>
    <Button href="/contact" variant="primary" size="lg">
      Iniciar Conversación
    </Button>
  </Section>
</BaseLayout>

<Icon name="building" size={1} style="display:none" />
