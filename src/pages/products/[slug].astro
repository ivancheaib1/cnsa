---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/ui/Section.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import Icon from '@/components/ui/Icon.astro';

const { slug } = Astro.params;

const productData: Record<string, any> = {
  'tintas-vernizes': {
    title: 'Tintas e Vernizes',
    icon: 'paint',
    subtitle: 'Pinturas de marcaje vial de alta reflectividad',
    description: 'Nuestras tintas y vernices ofrecen la máxima reflectividad y durabilidad para marcaje vial en cualquier condición climática.',
    features: [
      'Alta reflectividad nocturna',
      'Resistencia a rayos UV',
      'Durabilidad excepcional',
      'Fácil aplicación',
      'Eco-amigable',
    ],
    specs: {
      'Reflectividad': 'R3 (mínimo)',
      'Durabilidad': '24-36 meses',
      'Rendimiento': '8-10 m²/litro',
      'Secado': '30-60 minutos',
    },
  },
  'termoplasticos': {
    title: 'Termoplásticos',
    icon: 'truck',
    subtitle: 'Materiales termoplásticos con adherencia excepcional',
    description: 'Soluciones termoplásticas de última generación que combinan excelente adherencia con visibilidad nocturna superior.',
    features: [
      'Adherencia superior',
      'Máxima durabilidad',
      'Instalación rápida',
      'Reflectividad mejorada',
      'Resistencia al tráfico pesado',
    ],
    specs: {
      'Espesor': '2-4mm',
      'Temperatura aplicación': '160-200°C',
      'Durabilidad': '36-48 meses',
      'Reflectividad': 'RA1-RA2',
    },
  },
  'plastico-frio': {
    title: 'Plástico a Frio',
    icon: 'zap',
    subtitle: 'Aplicación de plástico sin requerir calor',
    description: 'Innovadora solución de aplicación en frío que elimina la necesidad de equipos de calentamiento, reduciendo costos y complejidad.',
    features: [
      'Aplicación sin calor',
      'Costos reducidos',
      'Instalación rápida',
      'Seguro para operarios',
      'Versátil',
    ],
    specs: {
      'Tiempo secado': '15-30 minutos',
      'Temperatura aplicación': 'Ambiente',
      'Durabilidad': '18-24 meses',
      'Rendimiento': '4-6 m²/componente',
    },
  },
  'piso-podotactil': {
    title: 'Piso Podotácil',
    icon: 'shield',
    subtitle: 'Pisos tácti para orientación de personas',
    description: 'Pisos podotácti especialmente diseñados para guiar y proteger a personas con discapacidad visual en espacios públicos.',
    features: [
      'Superficie táctil mejorada',
      'Durabilidad extrema',
      'Antideslizante',
      'Fácil limpieza',
      'Cumple estándares ISO',
    ],
    specs: {
      'Espesor': '3-5mm',
      'Coeficiente fricción': '0.6 mínimo',
      'Durabilidad': '48+ meses',
      'Instalación': 'Adhesiva o mecánica',
    },
  },
  'microesferas-vidrio': {
    title: 'Microesferas de Vidrio',
    icon: 'zap',
    subtitle: 'Perlas reflectoras de alta calidad',
    description: 'Microesferas de vidrio de grado óptico que proporcionan máxima reflectividad para sistemas de marcaje vial.',
    features: [
      'Reflectividad superior',
      'Grado óptico',
      'Tamaño uniforme',
      'Compatibilidad universal',
      'Durabilidad garantizada',
    ],
    specs: {
      'Tamaño partícula': '90-150 micras',
      'Densidad': '2.5 g/cm³',
      'Pureza': '99.9%',
      'Índice refracción': 'n=1.50',
    },
  },
  'tachas-tachoes': {
    title: 'Tachas e Tachões',
    icon: 'target',
    subtitle: 'Elementos de fijación para demarcación vial',
    description: 'Tachas y tachones de acero inoxidable y plástico reforzado para demarcación segura en carreteras y estacionamientos.',
    features: [
      'Durabilidad extrema',
      'Resistencia al impacto',
      'Reflectividad integrada',
      'Fácil instalación',
      'Múltiples colores',
    ],
    specs: {
      'Material': 'Acero inoxidable / Plástico',
      'Altura': '20-30mm',
      'Resistencia': 'Clase D400+',
      'Reflectores': 'Ópticos integrados',
    },
  },
  'colas-adesivos': {
    title: 'Colas e Adesivos',
    icon: 'briefcase',
    subtitle: 'Adhesivos especializados para aplicaciones viales',
    description: 'Colas y adhesivos de formulación especial diseñados para máxima adherencia en superficies viales de todo tipo.',
    features: [
      'Adherencia excepcional',
      'Resistencia ambiental',
      'Aplicación controlada',
      'Tiempos de secado optimizados',
      'Eco-responsables',
