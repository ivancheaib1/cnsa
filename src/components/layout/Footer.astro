---
import Icon from '@/components/ui/Icon.astro';

interface Props {
  lang?: 'es' | 'en' | 'pt';
}

const { lang = 'es' } = Astro.props;

const footerText = {
  es: {
    company: 'CNSA Paraguay',
    description: 'Soluciones premium de marcaje vial y seguridad en carreteras',
    products: 'Productos',
    solutions: 'Soluciones',
    projects: 'Proyectos',
    about: 'Sobre Nosotros',
    blog: 'Blog',
    contact: 'Contacto',
    followUs: 'Síguenos',
    rights: 'Todos los derechos reservados',
    year: new Date().getFullYear(),
  },
  en: {
    company: 'CNSA Paraguay',
    description: 'Premium road marking solutions and highway safety',
    products: 'Products',
    solutions: 'Solutions',
    projects: 'Projects',
    about: 'About',
    blog: 'Blog',
    contact: 'Contact',
    followUs: 'Follow Us',
    rights: 'All rights reserved',
    year: new Date().getFullYear(),
  },
  pt: {
    company: 'CNSA Paraguay',
    description: 'Soluções premium de marcação viária e segurança em estradas',
    products: 'Produtos',
    solutions: 'Soluções',
    projects: 'Projetos',
    about: 'Sobre',
    blog: 'Blog',
    contact: 'Contato',
    followUs: 'Siga-nos',
    rights: 'Todos os direitos reservados',
    year: new Date().getFullYear(),
  },
};

const text = footerText[lang as keyof typeof footerText] || footerText.es;
const baseUrl = lang === 'es' ? '' : `/${lang}`;
---

<footer class="bg-dark border-t border-primary/20">
  <div class="container-premium py-16">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <!-- Brand -->
      <div>
        <div class="w-10 h-10 bg-primary rounded-sm flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M3 4h18v2H3V4zm0 7h18v2H3v-2zm0 7h18v2H3v-2z"/>
          </svg>
        </div>
        <h3 class="font-body font-bold text-white mb-2">{text.company}</h3>
        <p class="text-gray text-sm mb-6">{text.description}</p>

        <!-- Social Links -->
        <div class="flex gap-3">
          <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-sm bg-dark-secondary flex items-center justify-center hover:bg-primary hover:text-white transition-colors duration-300">
            <Icon name="globe" size={18} />
          </a>
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-sm bg-dark-secondary flex items-center justify-center hover:bg-primary hover:text-white transition-colors duration-300">
            <Icon name="globe" size={18} />
          </a>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-sm bg-dark-secondary flex items-center justify-center hover:bg-primary hover:text-white transition-colors duration-300">
            <Icon name="globe" size={18} />
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-body font-bold text-white mb-6">{text.products}</h4>
        <ul class="space-y-3">
          <li><a href={`${baseUrl}/products`} class="text-gray hover:text-white transition-colors duration-300 text-sm">Pinturas Viales</a></li>
          <li><a href={`${baseUrl}/products`} class="text-gray hover:text-white transition-colors duration-300 text-sm">Materiales Termoplásticos</a></li>
          <li><a href={`${baseUrl}/products`} class="text-gray hover:text-white transition-colors duration-300 text-sm">Perlas de Vidrio</a></li>
          <li><a href={`${baseUrl}/products`} class="text-gray hover:text-white transition-colors duration-300 text-sm">Soluciones de Seguridad</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-body font-bold text-white mb-6">{text.about}</h4>
        <ul class="space-y-3">
          <li><a href={`${baseUrl}/about`} class="text-gray hover:text-white transition-colors duration-300 text-sm">{text.about}</a></li>
          <li><a href={`${baseUrl}/projects`} class="text-gray hover:text-white transition-colors duration-300 text-sm">{text.projects}</a></li>
          <li><a href={`${baseUrl}/blog`} class="text-gray hover:text-white transition-colors duration-300 text-sm">{text.blog}</a></li>
          <li><a href={`${baseUrl}/contact`} class="text-gray hover:text-white transition-colors duration-300 text-sm">{text.contact}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-body font-bold text-white mb-6">{text.contact}</h4>
        <ul class="space-y-3 text-gray text-sm">
          <li class="flex items-start gap-2">
            <Icon name="location" size={16} class="mt-0.5 flex-shrink-0" />
            <span>Asunción, Paraguay</span>
          </li>
          <li class="flex items-start gap-2">
            <Icon name="phone" size={16} class="mt-0.5 flex-shrink-0" />
            <span>+595 21 123 456</span>
          </li>
          <li class="flex items-start gap-2">
            <Icon name="email" size={16} class="mt-0.5 flex-shrink-0" />
            <span>info@cnsaparaguay.com</span>
          </li>
          <li class="flex items-start gap-2">
            <Icon name="clock" size={16} class="mt-0.5 flex-shrink-0" />
            <span>Lun-Vie: 8:00 - 18:00</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-[rgba(255,255,255,0.08)] pt-8 flex justify-between items-center flex-col md:flex-row gap-4">
      <p class="text-gray text-xs">© {text.year} {text.company}. {text.rights}. Made by <a href="https://www.quantex.com.py" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-white transition-colors duration-300">QUANTEX</a></p>
      <div class="flex gap-6 text-gray text-xs">
        <a href="/privacy" class="hover:text-white transition-colors duration-300">Privacidad</a>
        <a href="/terms" class="hover:text-white transition-colors duration-300">Términos</a>
        <a href="/cookies" class="hover:text-white transition-colors duration-300">Cookies</a>
      </div>
    </div>
  </div>
</footer>
