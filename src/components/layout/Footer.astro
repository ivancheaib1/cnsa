---
interface Props {
  lang?: 'es' | 'en' | 'pt';
}

const { lang = 'es' } = Astro.props;

const footerText = {
  es: {
    company: 'CNSA Paraguay',
    description: 'Soluciones premium de marcaje vial y seguridad en carreteras',
    products: 'Productos',
    solutions: 'Soluciones',
    projects: 'Proyectos',
    about: 'Nosotros',
    blog: 'Blog',
    contact: 'Contacto',
    followUs: 'Síguenos',
    rights: 'Todos los derechos reservados',
    year: new Date().getFullYear(),
  },
  en: {
    company: 'CNSA Paraguay',
    description: 'Premium road marking solutions and highway safety',
    products: 'Products',
    solutions: 'Solutions',
    projects: 'Projects',
    about: 'About',
    blog: 'Blog',
    contact: 'Contact',
    followUs: 'Follow us',
    rights: 'All rights reserved',
    year: new Date().getFullYear(),
  },
  pt: {
    company: 'CNSA Paraguay',
    description: 'Soluções premium de marcação viária e segurança em estradas',
    products: 'Produtos',
    solutions: 'Soluções',
    projects: 'Projetos',
    about: 'Sobre',
    blog: 'Blog',
    contact: 'Contato',
    followUs: 'Siga-nos',
    rights: 'Todos os direitos reservados',
    year: new Date().getFullYear(),
  },
};

const text = footerText[lang as keyof typeof footerText] || footerText.es;
const baseUrl = lang === 'es' ? '' : `/${lang}`;
---

<footer class="bg-dark-secondary border-t border-white/10 mt-20">
  <div class="container-premium py-16">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <!-- Brand -->
      <div>
        <div class="w-12 h-12 bg-primary rounded-lg flex items-center justify-center mb-4">
          <span class="font-heading font-bold text-dark">CNSA</span>
        </div>
        <h3 class="font-heading font-bold text-white mb-2">{text.company}</h3>
        <p class="text-neutral-gray text-sm">{text.description}</p>

        <!-- Social Links -->
        <div class="flex gap-4 mt-6">
          <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center hover:bg-primary hover:text-dark transition-colors duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5c-.563-.074-2.313-.229-4.425-.229-4.88 0-8.385 2.964-8.385 8.405v1.924z"></path>
            </svg>
          </a>
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center hover:bg-primary hover:text-dark transition-colors duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zM5.838 12a6.162 6.162 0 1112.324 0 6.162 6.162 0 01-12.324 0zM12 16a4 4 0 110-8 4 4 0 010 8zm4.965-10.322a1.44 1.44 0 110 2.881 1.44 1.44 0 010-2.881z"></path>
            </svg>
          </a>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center hover:bg-primary hover:text-dark transition-colors duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-heading font-bold text-white mb-6">{text.products}</h4>
        <ul class="space-y-3">
          <li><a href={`${baseUrl}/products`} class="text-neutral-gray hover:text-primary transition-colors duration-300">{text.products}</a></li>
          <li><a href={`${baseUrl}/products`} class="text-neutral-gray hover:text-primary transition-colors duration-300">Pinturas Viales</a></li>
          <li><a href={`${baseUrl}/products`} class="text-neutral-gray hover:text-primary transition-colors duration-300">Materiales Termoplásticos</a></li>
          <li><a href={`${baseUrl}/products`} class="text-neutral-gray hover:text-primary transition-colors duration-300">Perlas de Vidrio</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-heading font-bold text-white mb-6">{text.about}</h4>
        <ul class="space-y-3">
          <li><a href={`${baseUrl}/about`} class="text-neutral-gray hover:text-primary transition-colors duration-300">{text.about}</a></li>
          <li><a href={`${baseUrl}/projects`} class="text-neutral-gray hover:text-primary transition-colors duration-300">{text.projects}</a></li>
          <li><a href={`${baseUrl}/blog`} class="text-neutral-gray hover:text-primary transition-colors duration-300">{text.blog}</a></li>
          <li><a href={`${baseUrl}/contact`} class="text-neutral-gray hover:text-primary transition-colors duration-300">{text.contact}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-heading font-bold text-white mb-6">{text.contact}</h4>
        <ul class="space-y-3 text-neutral-gray text-sm">
          <li>📍 Asunción, Paraguay</li>
          <li>📞 +595 21 123 456</li>
          <li>📧 info@cnsaparaguay.com</li>
          <li>🕐 Lun-Vie: 8:00 - 18:00</li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/10 pt-8 flex justify-between items-center flex-col md:flex-row gap-4">
      <p class="text-neutral-gray text-sm">© {text.year} {text.company}. {text.rights}.</p>
      <div class="flex gap-6 text-neutral-gray text-sm">
        <a href="#" class="hover:text-primary transition-colors duration-300">Privacidad</a>
        <a href="#" class="hover:text-primary transition-colors duration-300">Términos</a>
        <a href="#" class="hover:text-primary transition-colors duration-300">Cookies</a>
      </div>
    </div>
  </div>
</footer>
