---
import Button from '@/components/ui/Button.astro';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  lang?: 'es' | 'en' | 'pt';
}

const { lang = 'es' } = Astro.props;

const products = [
  { label: 'Tintas e Vernizes', href: '/products/tintas-vernizes' },
  { label: 'Termoplásticos', href: '/products/termoplasticos' },
  { label: 'Plástico a Frio', href: '/products/plastico-frio' },
  { label: 'Piso Podotácil', href: '/products/piso-podotactil' },
  { label: 'Microesferas de Vidrio', href: '/products/microesferas-vidrio' },
  { label: 'Tachas e Tachões', href: '/products/tachas-tachoes' },
  { label: 'Colas e Adesivos', href: '/products/colas-adesivos' },
  { label: 'Pisos Industriales', href: '/products/pisos-industriales' },
  { label: 'Pisos Decorativos', href: '/products/pisos-decorativos' },
  { label: 'Préformados', href: '/products/preformados' },
];

const nav = {
  es: [
    { label: 'Inicio', href: '/' },
    { label: 'Nosotros', href: '/about' },
    { label: 'Productos', href: '/products', dropdown: products },
    { label: 'Proyectos', href: '/projects' },
    { label: 'Blog', href: '/blog' },
    { label: 'Contacto', href: '/contact' },
  ],
  en: [
    { label: 'Home', href: '/en/' },
    { label: 'About', href: '/en/about' },
    { label: 'Products', href: '/en/products' },
    { label: 'Projects', href: '/en/projects' },
    { label: 'Blog', href: '/en/blog' },
    { label: 'Contact', href: '/en/contact' },
  ],
  pt: [
    { label: 'Início', href: '/pt/' },
    { label: 'Sobre', href: '/pt/about' },
    { label: 'Produtos', href: '/pt/products' },
    { label: 'Projetos', href: '/pt/projects' },
    { label: 'Blog', href: '/pt/blog' },
    { label: 'Contato', href: '/pt/contact' },
  ],
};

const getNavigation = () => nav[lang as keyof typeof nav] || nav.es;
const currentNav = getNavigation();
---

<header id="main-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" style="background: transparent;">
  <div class="container-premium py-5 md:py-6 flex justify-between items-center">
    <!-- Logo -->
    <a href={lang === 'es' ? '/' : `/${lang}/`} class="flex items-center gap-2 group">
      <div class="w-10 h-10 bg-primary rounded-sm flex items-center justify-center group-hover:shadow-subtle transition-all">
        <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
          <path d="M3 4h18v2H3V4zm0 7h18v2H3v-2zm0 7h18v2H3v-2z"/>
        </svg>
      </div>
      <span class="font-body font-bold text-white text-sm hidden md:inline tracking-wide">CNSA PARAGUAY</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden lg:flex items-center gap-8">
      {currentNav.map(item => (
        <div key={item.label} class="relative group">
          <a href={item.href} class="text-gray hover:text-white transition-colors duration-300 text-sm font-medium uppercase tracking-wide flex items-center gap-1">
            {item.label}
            {(item as any).dropdown && <Icon name="chevron-down" size={14} class="group-hover:rotate-180 transition-transform duration-300" />}
          </a>
          {(item as any).dropdown && (
            <div class="absolute left-0 mt-0 w-48 bg-dark-secondary border border-[rgba(255,255,255,0.08)] rounded-sm shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 pt-2">
              {(item as any).dropdown.map((product: any) => (
                <a
                  href={product.href}
                  class="block px-4 py-3 text-xs text-gray hover:text-white hover:bg-dark-tertiary transition-colors duration-200 border-b border-[rgba(255,255,255,0.04)] last:border-b-0"
                >
                  {product.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>

    <!-- Language Switcher & CTA -->
    <div class="flex items-center gap-4">
      <!-- Language Switcher -->
      <div class="hidden md:flex gap-2">
        {['es', 'en', 'pt'].map(l => (
          <a
            href={l === 'es' ? '/' : `/${l}/`}
            class={`px-3 py-1 text-xs font-bold rounded-sm transition-colors duration-300 uppercase tracking-wider ${
              lang === l
                ? 'bg-primary text-white'
                : 'text-gray hover:text-white'
            }`}
          >
            {l}
          </a>
        ))}
      </div>

      <!-- CTA Button -->
      <a
        href={lang === 'es' ? '/contact' : `/${lang}/contact`}
        class="hidden sm:inline-block px-5 py-2.5 bg-primary text-white font-body font-bold text-sm rounded-sm hover:bg-primary/90 transition-all duration-300 uppercase tracking-wide"
      >
        {lang === 'es' ? 'Cotizar' : lang === 'en' ? 'Quote' : 'Orçamento'}
      </a>

      <!-- Mobile Menu Button -->
      <button
        class="lg:hidden w-10 h-10 flex items-center justify-center rounded-sm hover:bg-dark-secondary transition-colors duration-300"
        aria-label="Toggle menu"
        id="mobile-menu-btn"
      >
        <Icon name="menu" size={20} class="text-white" />
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <nav
    id="mobile-nav"
    class="hidden lg:hidden absolute top-full left-0 right-0 bg-dark-secondary border-b border-[rgba(255,255,255,0.08)] p-4 space-y-2"
  >
    {currentNav.map(item => (
      <a href={item.href} class="block text-gray hover:text-white transition-colors duration-300 py-3 text-sm font-medium uppercase tracking-wide border-b border-[rgba(255,255,255,0.04)]">
        {item.label}
      </a>
    ))}
    <a
      href={lang === 'es' ? '/contact' : `/${lang}/contact`}
      class="block mt-4 px-5 py-3 bg-primary text-white font-body font-bold text-center text-sm rounded-sm hover:bg-primary/90 transition-colors duration-300 uppercase tracking-wide"
    >
      {lang === 'es' ? 'Cotizar' : lang === 'en' ? 'Quote' : 'Orçamento'}
    </a>
  </nav>
</header>

<script>
  const header = document.getElementById('main-header') as HTMLElement;
  const mobileMenuBtn = document.getElementById('mobile-menu-btn') as HTMLButtonElement;
  const mobileNav = document.getElementById('mobile-nav') as HTMLElement;

  // Scroll-aware header
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header.style.background = 'rgba(8, 8, 8, 0.95)';
      header.style.backdropFilter = 'blur(20px)';
      header.style.borderBottom = '1px solid rgba(255, 255, 255, 0.08)';
    } else {
      header.style.background = 'transparent';
      header.style.backdropFilter = 'none';
      header.style.borderBottom = 'none';
    }
  });

  // Mobile menu toggle
  mobileMenuBtn?.addEventListener('click', () => {
    mobileNav?.classList.toggle('hidden');
  });

  // Close menu when link is clicked
  document.querySelectorAll('#mobile-nav a').forEach(link => {
    link.addEventListener('click', () => {
      mobileNav?.classList.add('hidden');
    });
  });
</script>
