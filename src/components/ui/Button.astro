---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  children?: any;
  type?: 'button' | 'submit' | 'reset';
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  type = 'button',
  children,
} = Astro.props;

const baseStyles = 'font-body font-bold rounded-sm transition-all duration-300 inline-flex items-center justify-center gap-2 whitespace-nowrap';

const variantStyles = {
  primary: 'bg-primary text-white hover:bg-primary/90 active:scale-95',
  secondary: 'border border-primary text-primary hover:bg-primary/10',
  ghost: 'text-gray-light hover:text-white',
  outline: 'border border-gray-light text-gray-light hover:border-white hover:text-white',
};

const lightModeOverrides = {
  primary: 'light-mode:bg-primary light-mode:text-white light-mode:hover:bg-primary/90',
  secondary: 'light-mode:border-primary light-mode:text-primary light-mode:hover:bg-primary/10',
  ghost: 'light-mode:text-gray-700 light-mode:hover:text-gray-900',
  outline: 'light-mode:border-gray-400 light-mode:text-gray-700 light-mode:hover:border-gray-900 light-mode:hover:text-gray-900 light-mode:hover:bg-gray-100',
};

const sizeStyles = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg font-semibold',
};

const combinedClass = `${baseStyles} ${variantStyles[variant]} ${lightModeOverrides[variant]} ${sizeStyles[size]} ${className}`;
---

{href ? (
  <a href={href} class={combinedClass}>
    <slot />
  </a>
) : (
  <button type={type} class={combinedClass}>
    <slot />
  </button>
)}
