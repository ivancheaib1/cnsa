---
interface Props {
  title?: string;
  subtitle?: string;
  class?: string;
  children?: any;
}

const { title, subtitle, class: className = '' } = Astro.props;
---

<section class={`py-20 md:py-32 ${className}`}>
  <div class="container-premium">
    {title && (
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-body font-bold text-white mb-4">{title}</h2>
        {subtitle && <p class="text-base text-gray max-w-3xl">{subtitle}</p>}
      </div>
    )}
    <slot />
  </div>
</section>
